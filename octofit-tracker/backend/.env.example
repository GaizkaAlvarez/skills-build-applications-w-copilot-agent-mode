# OctoFit Tracker Backend Environment Configuration

# Database
MONGODB_URL=mongodb://localhost:27017/octofit_db

# Server
PORT=8000

# Codespaces (automatically set in Codespaces environment)
# CODESPACE_NAME=your-codespace-name

# Frontend URL (for CORS)
# For localhost development, leave empty (defaults to http://localhost:5173)
# For Codespaces, this is automatically constructed as https://$CODESPACE_NAME-5173.app.github.dev

# Node Environment
NODE_ENV=development
